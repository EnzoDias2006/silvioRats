{
  "name": "silviorats",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @silviorats/api dev & bun --filter @silviorats/web dev",
    "build": "turbo run build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "bun --filter @silviorats/db db:generate",
    "db:migrate": "bun --filter @silviorats/db db:migrate",
    "prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "lefthook": "latest",
    "turbo": "latest",
    "typescript": "latest"
  }
}
