NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173
APP_URLS=http://localhost:5173,http://127.0.0.1:5173
API_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-at-least-32-characters-long
SILVIO_INSTANCE_ID=silvio-local-instance
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_NAME=Admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-at-least-8-characters
BOOTSTRAP_ADMIN_FORCE_RESET=false
COOKIE_DOMAIN=

DATABASE_URL=file:./data/silviorats.sqlite
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=silviorats
DO_SPACES_PUBLIC_URL=https://silviorats.nyc3.cdn.digitaloceanspaces.com/
DO_SPACES_ACCESS_KEY_ID=
DO_SPACES_SECRET_ACCESS_KEY=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Frontend (Vite)
VITE_BYPASS_PWA_CHECK=true
